# Backend environment variables
# App
PORT=5000

# MongoDB
MONGODB_URI=

# CORS allowlist (comma-separated)
# Production: https://shilpohaat.vercel.app
FRONTEND_ORIGINS=https://shilpohaat.vercel.app

# Frontend base URL used for redirects after payment
FRONTEND_URL=https://shilpohaat.vercel.app

# Backend public URL (this server), used for payment gateway callbacks
BACKEND_URL=https://shilpohaat.onrender.com

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SSLCommerz
STORE_ID=
STORE_PASSWORD=
# true for live mode, false for sandbox
IS_LIVE=false
