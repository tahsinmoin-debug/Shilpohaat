# Frontend environment variables
# Public API base URL used by Next.js client and server components
# Production (Render backend): https://shilpohaat.onrender.com
# Local dev: http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=https://shilpohaat.onrender.com
# Cloudinary cloud name used for on-the-fly CDN fetch + optimization
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dt0mwoirn
# Optional: needed if you want local/static site-relative images rewritten via Cloudinary fetch
NEXT_PUBLIC_SITE_URL=http://localhost:3000
